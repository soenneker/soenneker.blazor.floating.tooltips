@page "/"
@using Microsoft.Extensions.Logging
@using Target = Soenneker.Quark.Target
@using Soenneker.Blazor.Floating.Tooltips
@using Soenneker.Blazor.Floating.Tooltips.Enums
@using Soenneker.Blazor.Floating.Tooltips.Options
@inject ILogger<Index> Logger

<Div Space="Space.Y.Is6">
    <Paragraph TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground" Margin="Margin.Is0">
        Tooltips use
        <Anchor To="https://floating-ui.com" Target="Target.Blank" Rel="noreferrer">Floating UI</Anchor>
        for positioning.
    </Paragraph>

    <Grid Columns="Columns.Is1.OnMd.Is2" Gap="Gap.Is4">
        <DemoPanel Title="Basic text" Description="Simple string content.">
            <FloatingTooltip Text="Hello there">
                <Button>Hover me</Button>
            </FloatingTooltip>
        </DemoPanel>

        <DemoPanel Title="Custom content" Description="Arbitrary markup inside the tooltip.">
            <FloatingTooltip>
                <Span TextColor="TextColor.Primary" Class="cursor-default">Hover for details</Span>
                <Soenneker.Blazor.Floating.Tooltips.TooltipContent>
                    <Div Space="Space.Y.Is1">
                        <Strong>Tip:</Strong>
                        <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">
                            Tooltips can include markup such as <Code Inline="true">strong</Code> and <Code Inline="true">em</Code>.
                        </Paragraph>
                    </Div>
                </Soenneker.Blazor.Floating.Tooltips.TooltipContent>
            </FloatingTooltip>
        </DemoPanel>

        <DemoPanel Title="Delayed" Description="Show and hide delays with animation.">
            <FloatingTooltip Text="Delayed and animated tooltip" Options="@_delayedOptions">
                <Button Variant="ButtonVariant.Secondary">Delayed tooltip</Button>
            </FloatingTooltip>
        </DemoPanel>

        <DemoPanel Title="Image" Description="Rich content preview.">
            <FloatingTooltip>
                <Span Class="cursor-default">Hover for image</Span>
                <Soenneker.Blazor.Floating.Tooltips.TooltipContent>
                    <img src="https://picsum.photos/100/60" alt="Preview" class="rounded-md" />
                </Soenneker.Blazor.Floating.Tooltips.TooltipContent>
            </FloatingTooltip>
        </DemoPanel>

        <DemoPanel Title="Disabled" Description="Tooltip can be turned off while the anchor stays visible.">
            <FloatingTooltip Text="You will not see this" Options="@_disabledOptions">
                <Button Variant="ButtonVariant.Destructive" Disabled>Disabled target</Button>
            </FloatingTooltip>
        </DemoPanel>

        <DemoPanel Title="Manual trigger" Description="Toggle visibility from code.">
            <FloatingTooltip ManualTrigger="true" @ref="_manualTooltip" Text="Controlled manually.">
                <Button Variant="ButtonVariant.Outline" OnClick="Toggle">Toggle tooltip</Button>
            </FloatingTooltip>
        </DemoPanel>

        <DemoPanel Title="Interactive" Description="Pointer can move into the tooltip.">
            <FloatingTooltip Interactive="true">
                <Span Class="cursor-default" TextColor="TextColor.Primary">Hover for interactive tooltip</Span>
                <Soenneker.Blazor.Floating.Tooltips.TooltipContent>
                    <Div Space="Space.Y.Is2" TextAlignment="TextAlignment.Center">
                        <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm">Click inside:</Paragraph>
                        <Button OnClick="LogTooltipClick">Inside</Button>
                    </Div>
                </Soenneker.Blazor.Floating.Tooltips.TooltipContent>
            </FloatingTooltip>
        </DemoPanel>

        <DemoPanel Title="OnShow / OnHide" Description="Events log to the browser console.">
            <FloatingTooltip Text="Logging tooltip" OnShow="OnShow" OnHide="OnHide">
                <Button Variant="ButtonVariant.Outline">Hover with logging</Button>
            </FloatingTooltip>
        </DemoPanel>
    </Grid>

    <DemoPanel Title="Placement" Description="One sample button per placement enum.">
        <DemoButtonRow>
            @foreach (FloatingTooltipPlacement placement in FloatingTooltipPlacement.List)
            {
                <FloatingTooltip Text="@($"Placed: {placement.Value}")" Placement="@placement">
                    <Button Variant="ButtonVariant.Outline">@placement.Value</Button>
                </FloatingTooltip>
            }
        </DemoButtonRow>
    </DemoPanel>

    <DemoPanel Title="Theme" Description="Built-in theme presets.">
        <DemoButtonRow>
            @foreach (FloatingTooltipTheme theme in FloatingTooltipTheme.List)
            {
                <FloatingTooltip Text="@($"Theme: {theme.Value}")" Theme="@theme">
                    <Button Variant="ButtonVariant.Secondary">@theme.Value</Button>
                </FloatingTooltip>
            }
        </DemoButtonRow>
    </DemoPanel>

    <DemoPanel Title="Max width" Description="Long text wraps instead of overflowing.">
        <FloatingTooltip MaxWidth="@("150")" Text="This is a long tooltip with a max width, which will wrap nicely instead of going off-screen.">
            <Button Variant="ButtonVariant.Outline">Wrapped tooltip</Button>
        </FloatingTooltip>
    </DemoPanel>

    <DemoPanel Title="Constraining" Description="Tooltip should not shrink the card or constrain unrelated inputs.">
        <Grid Columns="Columns.Is1" Gap="Gap.Is4">
            <Card>
                <FloatingTooltip Text="@($"This is a long line, and isn't constrained by parent elements. The next line is below this one: \n New line")">
                    <CardBody TextAlignment="TextAlignment.Center">
                        <CardTitle Size="4" TextColor="TextColor.MutedForeground">Card title</CardTitle>
                        <Heading Size="HeadingSize.Is3" Padding="Padding.Is1.OnY" Margin="Margin.Is2.OnY">
                            Heading inside tooltip target
                        </Heading>
                    </CardBody>
                </FloatingTooltip>
            </Card>

            <Field>
                <FloatingTooltip Text="@("This should not constrain the input")">
                    <FieldBody>
                        <Input Id="constrain-demo" Type="number" @bind-Value="_constrainNumber" />
                    </FieldBody>
                    <FieldLabel For="constrain-demo">Numeric input</FieldLabel>
                </FloatingTooltip>
            </Field>
        </Grid>
    </DemoPanel>
</Div>

@code {
    private string _constrainNumber = "0";

    private FloatingTooltip? _manualTooltip;

    private readonly FloatingTooltipOptions _delayedOptions = new()
    {
        Animate = true,
        ShowArrow = true,
        ShowDelay = 500,
        HideDelay = 300,
        Theme = FloatingTooltipTheme.Dark,
        MaxWidth = 220
    };

    private readonly FloatingTooltipOptions _disabledOptions = new()
    {
        Enabled = false
    };

    private async Task Toggle() => await _manualTooltip!.Toggle();

    private void LogTooltipClick() => Logger.LogInformation("Clicked inside tooltip");

    private void OnShow() => Logger.LogInformation("Tooltip shown");

    private void OnHide() => Logger.LogInformation("Tooltip hidden");
}
